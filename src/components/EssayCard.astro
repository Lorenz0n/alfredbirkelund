---
import type { CollectionEntry } from 'astro:content';
import { readingMinutes } from '~/lib/reading-time';

interface Props {
  essay: CollectionEntry<'essays'>;
  showDate?: boolean;
}

const { essay, showDate = true } = Astro.props;
const { title, subtitle, date } = essay.data;

const formatted = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const minutes = readingMinutes(essay.body);
---
<a class="essay-card" href={`/essays/${essay.slug}/`} data-category={essay.data.category}>
  {showDate && (
    <span class="essay-card__date meta">
      {formatted}<span class="essay-card__sep"> · </span>{minutes} min read
    </span>
  )}
  <div class="essay-card__title">{title}</div>
  {subtitle && <div class="essay-card__subtitle">{subtitle}</div>}
</a>
