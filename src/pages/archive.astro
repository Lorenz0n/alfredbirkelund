---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EssayCard from '../components/EssayCard.astro';

const essays = await getCollection('essays', ({ data }) => !data.draft);
essays.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const recent = essays.slice(0, 5);

const groups = new Map<number, CollectionEntry<'essays'>[]>();
for (const essay of essays) {
  const y = essay.data.date.getFullYear();
  if (!groups.has(y)) groups.set(y, []);
  groups.get(y)!.push(essay);
}
const years = [...groups.keys()].sort((a, b) => b - a);

const mmdd = (d: Date) =>
  `${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}`;
---
<BaseLayout title="Archive — Alfred Birkelund">
  <div class="canopy" aria-hidden="true">
    <svg viewBox="0 0 1200 180" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMax slice">
      <!-- Darkest back fringe -->
      <path d="M0,0 L0,80
               C 80,120 160,70 240,100
               C 320,130 400,80 480,110
               C 560,140 640,90 720,120
               C 800,150 880,100 960,130
               C 1040,160 1120,110 1200,140
               L 1200,0 Z"
            fill="#253a24" opacity="0.85" />
      <!-- Middle layer -->
      <path d="M0,0 L0,55
               C 60,100 140,55 220,80
               C 300,105 380,60 460,85
               C 540,110 620,65 700,90
               C 780,115 860,70 940,95
               C 1020,120 1100,75 1200,95
               L 1200,0 Z"
            fill="#3d5a3a" opacity="0.65" />
      <!-- Front fringe with organic bumps -->
      <path d="M0,0 L0,35
               C 40,75 100,25 160,50
               C 220,75 280,35 340,60
               C 400,85 460,40 520,60
               C 580,80 640,30 700,50
               C 760,70 820,25 880,50
               C 940,75 1000,30 1060,55
               C 1120,80 1170,45 1200,60
               L 1200,0 Z"
            fill="#2e4a2c" opacity="0.9" />
      <!-- Scattered foliage — soft leaves -->
      <g fill="#3d5a3a" opacity="0.55">
        <ellipse cx="80"   cy="130" rx="12" ry="5" transform="rotate(-10 80 130)" />
        <ellipse cx="220"  cy="148" rx="10" ry="4" transform="rotate(8 220 148)" />
        <ellipse cx="380"  cy="138" rx="14" ry="6" transform="rotate(-12 380 138)" />
        <ellipse cx="540"  cy="158" rx="11" ry="4" transform="rotate(5 540 158)" />
        <ellipse cx="700"  cy="143" rx="13" ry="5" transform="rotate(-8 700 143)" />
        <ellipse cx="860"  cy="160" rx="10" ry="4" transform="rotate(15 860 160)" />
        <ellipse cx="1020" cy="138" rx="12" ry="5" transform="rotate(-6 1020 138)" />
      </g>
      <!-- Closer leaves, darker for depth -->
      <g fill="#253a24" opacity="0.7">
        <ellipse cx="150"  cy="95" rx="15" ry="6" transform="rotate(-15 150 95)" />
        <ellipse cx="450"  cy="78" rx="16" ry="7" transform="rotate(12 450 78)" />
        <ellipse cx="750"  cy="88" rx="14" ry="6" transform="rotate(-10 750 88)" />
        <ellipse cx="1050" cy="82" rx="15" ry="7" transform="rotate(8 1050 82)" />
      </g>
    </svg>
  </div>

  <section class="reading archive-head">
    <h1>Archive</h1>
    <nav class="archive-nav meta" aria-label="Sections">
      <a href="#most-recent">Most recent</a>
      <span class="archive-nav__sep">·</span>
      <a href="#archived-posts">Archive</a>
    </nav>
  </section>

  {recent.length > 0 && (
    <section id="most-recent" class="reading section">
      <div class="section__head">
        <h2 class="section__title">Most recent</h2>
      </div>
      <div class="essays">
        {recent.map((essay) => <EssayCard essay={essay} />)}
      </div>
    </section>
  )}

  <section id="archived-posts" class="reading section">
    <div class="section__head">
      <h2 class="section__title">Archived posts</h2>
    </div>
    {essays.length > 0 ? (
      <div class="archive">
        {years.map((year) => (
          <div class="archive-year">
            <h3 class="archive-year-heading">{year}</h3>
            <ul class="archive-list">
              {groups.get(year)!.map((essay) => (
                <li class="archive-row">
                  <span class="archive-row__date meta">[{mmdd(essay.data.date)}]</span>
                  <a class="archive-row__title" href={`/essays/${essay.slug}/`}>
                    {essay.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    ) : (
      <p class="meta">No published essays yet.</p>
    )}
  </section>
</BaseLayout>
