---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---
{filtered.length > 0 && (
  <nav class="toc" aria-label="Table of contents">
    <div class="toc__title smallcaps">Contents</div>
    <ol class="toc__list">
      {filtered.map((h) => (
        <li class={`toc__item toc__item--depth-${h.depth}`}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ol>
  </nav>
)}
