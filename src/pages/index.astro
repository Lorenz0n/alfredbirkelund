---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Canopy from '../components/Canopy.astro';
import EssayCard from '../components/EssayCard.astro';

const allEssays = await getCollection('essays', ({ data }) => !data.draft);
allEssays.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latest = allEssays.slice(0, 3);
---
<BaseLayout title="Alfred Birkelund">
  <Canopy />
  <section class="reading intro">
    <p class="lead">
      I'm Alfred Birkelund — an economics student at the University of Southern
      Denmark and the builder of <a href="https://convictioninvest.com">Conviction</a>,
      an investment research platform. I write here about economics, finance,
      technology, and occasionally philosophy.
    </p>
    <p>
      You can reach me at
      <a href="mailto:alfredbirkelund@gmail.com">alfredbirkelund@gmail.com</a>
      or read <a href="#about">more about me below</a>.
    </p>
  </section>

  <div class="reading"><hr /></div>

  {latest.length > 0 && (
    <section class="reading section">
      <div class="section__head">
        <h2 class="section__title">Latest</h2>
        <a class="section__link" href="/archive">View all essays →</a>
      </div>
      <div class="essays">
        {latest.map((essay) => <EssayCard essay={essay} />)}
      </div>
    </section>
  )}

  <div class="reading"><hr /></div>

  <section id="about" class="reading about">
    <h2>About</h2>
    <p>
      I'm finishing a BSc in Economics at the University of Southern Denmark.
    </p>
    <p>
      The usual way to read a decision is to follow the money, and most of
      the time it works. But if AI is a shift on the scale of the industrial
      revolution — and I think it is — capital will have rivals: security,
      data, and political ambition.
    </p>
    <p>
      Alongside my studies I'm building
      <a href="https://convictioninvest.com">Conviction</a> — an investment
      research platform that synthesizes insider transactions, institutional
      filings, and company fundamentals into a proprietary conviction score,
      so that investors can gain greater insight into company valuation.
    </p>
    <p>
      The best way to reach me is by email:
      <a href="mailto:alfredbirkelund@gmail.com">alfredbirkelund@gmail.com</a>.
      I reply to most things.
    </p>
  </section>
</BaseLayout>
