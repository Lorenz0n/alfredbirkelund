---
import BaseLayout from '../layouts/BaseLayout.astro';
import Canopy from '../components/Canopy.astro';
---
<BaseLayout
  title="Colophon — Alfred Birkelund"
  description="Privacy, corrections, and contact."
>
  <Canopy />
  <article class="essay reading">
    <header class="essay__header">
      <h1 class="essay__title">Colophon</h1>
    </header>

    <div class="essay__body">
      <h2>Privacy</h2>
      <p>
        No cookies, no analytics, no tracking pixels, no embedded widgets, no
        forms. Fonts are self-hosted, so rendering a page doesn't send any
        request to Google or a third-party CDN. Visiting this site means your
        browser asks GitHub's servers for HTML, CSS, and fonts — and that's
        the whole exchange.
      </p>
      <p>
        GitHub, like any web host, keeps short-lived access logs (IP, user
        agent, request path) for the purpose of operating the service. I don't
        have access to those logs, and nothing on this site is designed to
        identify or profile visitors.
      </p>

      <h2>Corrections &amp; contact</h2>
      <p>
        If you have any amendments, questions, or concerns, please email me at
        <a href="mailto:alfredbirkelund@gmail.com">alfredbirkelund@gmail.com</a>.
      </p>

      <p class="meta">Last updated: April 2026.</p>
    </div>

    <footer class="essay__footer">
      <a href="/">← Home</a>
    </footer>
  </article>
</BaseLayout>
