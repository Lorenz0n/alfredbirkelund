---
import BaseLayout from '../layouts/BaseLayout.astro';
import Canopy from '../components/Canopy.astro';
import { profile, education, work } from '../data/cv';
---
<BaseLayout title={`CV — ${profile.name}`} description={profile.tagline}>
  <Canopy />
  <article class="cv reading">
    <header class="cv__header">
      <h1 class="cv__name">{profile.name}</h1>
      <p class="cv__tagline">{profile.tagline}</p>
      <p class="cv__contact meta">
        <span>{profile.location}</span>
        <span class="cv__sep"> · </span>
        <a href={`mailto:${profile.email}`}>{profile.email}</a>
        <span class="cv__sep"> · </span>
        <a href="/">{profile.site}</a>
        {profile.connections.map((c) => (
          <>
            <span class="cv__sep"> · </span>
            <a href={c.url}>{c.label}</a>
          </>
        ))}
      </p>
      <div class="cv__actions">
        <button type="button" class="cv__print" onclick="window.print()">
          Download as PDF
        </button>
      </div>
    </header>

    <section class="cv__section">
      <h2 class="cv__section-title">Education</h2>
      <ul class="cv__list">
        {education.map((e) => (
          <li class="cv__entry">
            <div class="cv__entry-primary">
              {e.degree}, {e.institution}
            </div>
            <div class="cv__entry-meta meta">
              {e.location && <>{e.location} · </>}
              {e.dates}
            </div>
            {e.note && <p class="cv__entry-note">{e.note}</p>}
          </li>
        ))}
      </ul>
    </section>

    <section class="cv__section">
      <h2 class="cv__section-title">Work</h2>
      <ul class="cv__list">
        {work.map((w) => (
          <li class="cv__entry">
            <div class="cv__entry-primary">
              {w.role} · {w.url ? <a href={w.url}>{w.organization}</a> : w.organization}
            </div>
            <div class="cv__entry-meta meta">
              {w.location && <>{w.location} · </>}
              {w.dates}
            </div>
            <p class="cv__entry-note">{w.description}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="cv__section">
      <h2 class="cv__section-title">Contact</h2>
      <p>
        Email <a href={`mailto:${profile.email}`}>{profile.email}</a>. I read
        everything and reply to most things.
      </p>
    </section>
  </article>
</BaseLayout>
