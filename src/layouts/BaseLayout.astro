---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Self-hosted fonts — bundled at build, no third-party (Google Fonts) request
// on page load. See /colophon for why.
import '@fontsource/eb-garamond/400.css';
import '@fontsource/eb-garamond/500.css';
import '@fontsource/eb-garamond/400-italic.css';
import '@fontsource/eb-garamond/500-italic.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';

import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Alfred Birkelund — essays on economics, finance, technology, and philosophy.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Alfred Birkelund — Essays" href="/rss.xml" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />

    <script is:inline>
      // Clean print: clear document.title briefly before window.print() so
      // the browser-injected page header doesn't repeat the title that's
      // already shown in the body. Restored after the print dialog closes.
      // Triggered by any button with data-print-clean.
      document.addEventListener('click', (e) => {
        const btn = e.target.closest('[data-print-clean]');
        if (!btn) return;
        e.preventDefault();
        const original = document.title;
        document.title = '';
        setTimeout(() => {
          window.print();
          document.title = original;
        }, 50);
      });
    </script>
  </body>
</html>
